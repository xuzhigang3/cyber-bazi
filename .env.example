# AI Provider Configuration
# Supported: gemini, openai
AI_PROVIDER="gemini"
# Optional: gemini-2.0-flash, gpt-4o, etc.
AI_MODEL="gemini-2.0-flash"

# Google Gemini (if using AI_PROVIDER="gemini")
# Get this from https://aistudio.google.com/
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# OpenAI or OpenAI-compatible (if using AI_PROVIDER="openai")
# e.g., https://api.openai.com/v1 or https://api.deepseek.com
OPENAI_API_KEY="your_openai_api_key_here"
OPENAI_BASE_URL="https://api.openai.com/v1"

# APP_URL: The URL where this applet is hosted.
# Used for Stripe success/cancel redirect URLs.
APP_URL="http://localhost:3000"

# Lemon Squeezy configuration
# Get this from https://app.lemonsqueezy.com/settings/api
LEMON_SQUEEZY_API_KEY="your_api_key_here"
LEMON_SQUEEZY_STORE_ID="your_store_id"
LEMON_SQUEEZY_VARIANT_ID="your_variant_id"
LEMON_SQUEEZY_WEBHOOK_SECRET="your_webhook_secret"
